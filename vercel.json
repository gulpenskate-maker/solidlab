{
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/qr/card-ulrik",
      "destination": "https://solidlab.ai/",
      "permanent": false
    },
    {
      "source": "/qr/card-solidlab",
      "destination": "https://solidlab.ai/",
      "permanent": false
    },
    {
      "source": "/qr/card-charlotte",
      "destination": "https://solidlab.ai/",
      "permanent": false
    },
    {
      "source": "/qr/sticker",
      "destination": "https://solidlab.ai/",
      "permanent": false
    },
    {
      "source": "/qr/hangtag",
      "destination": "https://solidlab.ai/",
      "permanent": false
    },
    {
      "source": "/qr/merch",
      "destination": "https://solidlab.ai/",
      "permanent": false
    }
  ],
  "headers": [
    {
      "source": "/fonts/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" },
        { "key": "Access-Control-Allow-Origin", "value": "*" }
      ]
    },
    {
      "source": "/(.*\\.css)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
